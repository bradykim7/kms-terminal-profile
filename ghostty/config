# Font
font-family = Hack Nerd Font
font-size = 14
font-thicken = true

# Theme
theme = Nord Light

# Window
window-padding-x = 8
window-padding-y = 8

# Cursor
cursor-style = block

# Keybind
keybind = global:cmd+grave_accent=toggle_quick_terminal

# Clipboard
copy-on-select = clipboard

# Shell
shell-integration = detect
shell-integration-features = cursor,sudo,title
